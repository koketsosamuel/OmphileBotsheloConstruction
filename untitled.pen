              "name": "Story Image",
              "metadata": {
                "type": "unsplash",
                "username": "markwilliamspics",
                "link": "https://unsplash.com/@markwilliamspics",
                "author": "Mark Williams"
              },
              "width": 620,
              "height": 620,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1572217278174-ea3eb3f3bc8b?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzQwNTQzNzZ8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"
              }
            },
            {
              "type": "frame",
              "id": "eleea",
              "name": "Story Content",
              "width": "fill_container",
              "height": 620,
              "layout": "vertical",
              "gap": 20,
              "padding": [
                72,
                64
              ],
              "justifyContent": "center",
              "children": [
                {
                  "type": "text",
                  "id": "RYE9h",
                  "name": "storyLabel",
                  "fill": "#1B3A6B",
                  "content": "OUR STORY",
                  "fontFamily": "Outfit",
                  "fontSize": 11,
                  "fontWeight": "600",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "Nf0Gc",
                  "name": "storyTitle",
                  "fill": "#2B2D2F",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Built on Trust,\nGrown Through Service",
                  "lineHeight": 1.2,
                  "fontFamily": "DM Serif Display",
                  "fontSize": 40,
                  "fontWeight": "700"
                },
                {
                  "type": "rectangle",
                  "id": "Ft8OE",
                  "name": "storyDivider",
                  "fill": "#1B3A6B",
                  "width": 48,
                  "height": 3
                },
                {
                  "type": "text",
                  "id": "vx4AZ",
                  "name": "storyP1",
                  "fill": "#4A4E54",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Omphile Botshelo Construction was established in 2008 with a clear vision: to be a construction company that not only builds structures but builds futures. Founded in Gauteng, we have grown from a small local contractor into a nationally recognised construction firm.",
                  "lineHeight": 1.8,
                  "fontFamily": "Outfit",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "u4wsT",
                  "name": "storyP2",
                  "fill": "#4A4E54",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We have successfully delivered government housing projects, municipal infrastructure, commercial developments, and community facilities across South Africa. Our work spans Gauteng, Limpopo, North West, and beyond.",
                  "lineHeight": 1.8,
