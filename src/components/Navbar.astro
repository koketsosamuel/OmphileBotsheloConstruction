---
interface Props {
  active?: string;
}

const { active = 'Home' } = Astro.props;

const links = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Projects', href: '/projects' },
  { name: 'Compliance', href: '/compliance' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50">
<nav class="bg-obc-dark flex items-center justify-between px-6 lg:px-14 h-20">
  <a href="/">
    <img src="/logo.png" alt="Omphile Botshelo Construction" class="h-14 w-auto object-contain" />
  </a>

  <!-- Desktop Nav -->
  <div class="hidden lg:flex items-center gap-9">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'text-xs font-semibold tracking-widest uppercase transition-colors',
          active === link.name ? 'text-obc-cream' : 'text-obc-muted hover:text-obc-cream',
        ]}
      >
        {link.name}
      </a>
    ))}
  </div>

  <div class="hidden lg:block">
    <a
      href="/contact"
      class="bg-obc-orange text-obc-cream text-xs font-bold tracking-widest px-6 py-3 uppercase hover:bg-orange-700 transition-colors"
    >
      GET A QUOTE
    </a>
  </div>

  <!-- Mobile Menu Button -->
  <button id="mobile-menu-btn" class="lg:hidden text-obc-cream" aria-label="Open menu">
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden lg:hidden bg-obc-dark px-6 pb-6">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'block py-3 text-sm font-semibold tracking-wider uppercase border-b border-obc-divider',
        active === link.name ? 'text-obc-cream' : 'text-obc-muted',
      ]}
    >
      {link.name}
    </a>
  ))}
  <a
    href="/contact"
    class="block mt-4 bg-obc-orange text-obc-cream text-center text-sm font-bold tracking-wider px-6 py-3 uppercase"
  >
    GET A QUOTE
  </a>
</div>

</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
