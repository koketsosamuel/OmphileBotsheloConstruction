---
interface Props {
  heading: string;
  subtext: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { heading, subtext, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="bg-obc-orange py-16 lg:py-20 px-6 lg:px-20 flex flex-col items-center justify-center text-center gap-6">
  <h2 class="font-heading text-obc-cream text-3xl lg:text-[52px] leading-tight" set:html={heading} />
  <p class="text-obc-tan text-base lg:text-lg max-w-[600px]">{subtext}</p>
  <div class="flex flex-col sm:flex-row gap-4">
    <a
      href={primaryHref}
      class="bg-obc-cream text-obc-orange text-sm font-bold tracking-wider px-8 lg:px-10 py-4 uppercase hover:bg-white transition-colors"
    >
      {primaryLabel}
    </a>
    {secondaryLabel && secondaryHref && (
      <a
        href={secondaryHref}
        class="border-2 border-obc-cream text-obc-cream text-sm font-bold tracking-wider px-8 lg:px-10 py-4 uppercase hover:bg-obc-cream hover:text-obc-orange transition-colors"
      >
        {secondaryLabel}
      </a>
    )}
  </div>
</section>
