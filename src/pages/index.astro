---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import {
  HardHat,
  Building2,
  Landmark,
  Wrench,
  CircleCheck,
  BadgeCheck,
  Users,
  FileCheck,
  Database,
  Shield,
  Award,
  ShieldCheck,
  Layers,
} from 'lucide-astro';
import { getImage } from 'astro:assets';
import heroSrc from '../assets/images/hero.jpg';

const heroImage = await getImage({ src: heroSrc, format: 'webp', quality: 75 });
---

<Layout title="Home">
  <Navbar active="Home" />

  <!-- ===== HERO SECTION ===== -->
  <section
    class="relative flex items-center justify-center text-center px-6 min-h-[480px] lg:min-h-[700px]"
    style={`background-image: url('${heroImage.src}'); background-size: cover; background-position: center;`}
  >
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/60"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-6 max-w-4xl mx-auto">
      <h1 class="font-heading text-obc-cream text-4xl lg:text-6xl leading-tight">
        South Africa's First Preferred Leading Developmental Practice
      </h1>
      <p class="text-obc-tan text-base lg:text-lg max-w-2xl leading-relaxed">
        A 100% B-BBEE company delivering Construction, Supply and Training — serving clients professionally and with integrity across South Africa.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-2">
        <a
          href="/projects"
          class="bg-obc-orange text-obc-cream text-xs font-bold tracking-widest px-8 py-4 uppercase hover:bg-orange-700 transition-colors"
        >
          VIEW OUR PROJECTS
        </a>
        <a
          href="/contact"
          class="border-2 border-obc-cream text-obc-cream text-xs font-bold tracking-widest px-8 py-4 uppercase hover:bg-obc-cream hover:text-obc-dark transition-colors"
        >
          REQUEST A QUOTE
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CREDIBILITY BAR ===== -->
  <section class="bg-obc-dark py-10 px-6 lg:px-20">
    <div class="flex flex-wrap justify-between items-center gap-8 lg:gap-0 max-w-5xl mx-auto lg:max-w-none">
      <!-- Stat: Projects -->
      <div class="flex flex-col items-center gap-1 flex-1 min-w-[120px]">
        <span class="font-heading text-5xl text-obc-tan">6</span>
        <span class="text-xs font-semibold tracking-widest text-obc-muted uppercase">PROJECTS DELIVERED</span>
      </div>
      <!-- Divider -->
      <div class="hidden lg:block w-px h-12 bg-obc-divider"></div>
      <!-- Stat: Contract Value -->
      <div class="flex flex-col items-center gap-1 flex-1 min-w-[120px]">
        <span class="font-heading text-5xl text-obc-tan">R4M+</span>
        <span class="text-xs font-semibold tracking-widest text-obc-muted uppercase">TOTAL CONTRACT VALUE</span>
      </div>
      <!-- Divider -->
      <div class="hidden lg:block w-px h-12 bg-obc-divider"></div>
      <!-- Stat: B-BBEE -->
      <div class="flex flex-col items-center gap-1 flex-1 min-w-[120px]">
        <span class="font-heading text-5xl text-obc-tan">100%</span>
        <span class="text-xs font-semibold tracking-widest text-obc-muted uppercase">B-BBEE OWNED</span>
      </div>
      <!-- Divider -->
      <div class="hidden lg:block w-px h-12 bg-obc-divider"></div>
      <!-- Stat: CIDB -->
      <div class="flex flex-col items-center gap-1 flex-1 min-w-[120px]">
        <span class="font-heading text-5xl text-obc-orange">CIDB</span>
        <span class="text-xs font-semibold tracking-widest text-obc-muted uppercase">REG. 10032299</span>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT TEASER ===== -->
  <section class="flex flex-col lg:flex-row min-h-[560px]">
    <!-- Image Column -->
    <div class="lg:w-1/2 min-h-[300px] lg:min-h-0">
      <img
        src="/images/index-about.jpg"
        alt="Construction team at work"
        class="w-full h-full object-cover"
        style="min-height: 300px;"
        loading="lazy"
      />
    </div>

    <!-- Text Column -->
    <div class="lg:w-1/2 bg-obc-cream flex flex-col gap-5 p-8 lg:p-14 justify-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR STORY</span>
      <h2 class="font-heading text-obc-dark text-3xl lg:text-4xl leading-tight">Built on Trust, Delivering Value</h2>
      <div class="w-12 h-[3px] bg-obc-orange"></div>

      <p class="text-obc-body text-sm leading-relaxed">
        OMPHILE BOTSHELO (Pty) Ltd is a 100% Broad Based Black Economic Empowerment Company with four distinctive disciplines in Construction, Supply and Training. Our team has extensive experience of providing professional services where needed and works as a collective to accomplish our goals.
      </p>
      <p class="text-obc-body text-sm leading-relaxed">
        Our mission is to become the first preferred leading service provider of choice to accommodate black economic growth in South Africa. We serve our clients professionally and with integrity in all services we provide.
      </p>
      <p class="text-obc-body text-sm leading-relaxed">
        We create a good platform and career introduction to the youth of South Africa, and provide excellent value for money solutions to our clients — from municipal infrastructure to renovation and supply contracts across North West province and beyond.
      </p>

      <!-- Checklist -->
      <div class="flex flex-col gap-3 mt-1">
        <div class="flex items-center gap-3">
          <CircleCheck class="text-obc-orange flex-shrink-0" size={18} />
          <span class="text-obc-dark text-sm font-medium">100% B-BBEE owned company</span>
        </div>
        <div class="flex items-center gap-3">
          <CircleCheck class="text-obc-orange flex-shrink-0" size={18} />
          <span class="text-obc-dark text-sm font-medium">CIDB Registered (No. 10032299)</span>
        </div>
        <div class="flex items-center gap-3">
          <CircleCheck class="text-obc-orange flex-shrink-0" size={18} />
          <span class="text-obc-dark text-sm font-medium">NHBRC &amp; COIDA certified</span>
        </div>
      </div>

      <div class="mt-2">
        <a
          href="/about"
          class="inline-block bg-obc-orange text-obc-cream text-sm font-bold tracking-wider px-7 py-3 uppercase hover:bg-orange-700 transition-colors"
        >
          Learn More About Us
        </a>
      </div>
    </div>
  </section>

  <!-- Values Strip -->
  <div class="bg-obc-tan py-5 flex justify-center flex-wrap">
    <div class="flex items-center flex-wrap justify-center">
      <span class="text-obc-dark text-xs font-semibold tracking-[2px] px-8 uppercase py-2">INTEGRITY</span>
      <div class="w-px h-4 bg-obc-dark/20"></div>
      <span class="text-obc-dark text-xs font-semibold tracking-[2px] px-8 uppercase py-2">QUALITY</span>
      <div class="w-px h-4 bg-obc-dark/20"></div>
      <span class="text-obc-dark text-xs font-semibold tracking-[2px] px-8 uppercase py-2">RESPONSIVENESS</span>
      <div class="w-px h-4 bg-obc-dark/20"></div>
      <span class="text-obc-dark text-xs font-semibold tracking-[2px] px-8 uppercase py-2">IMPROVEMENT</span>
    </div>
  </div>

  <!-- ===== SERVICES SECTION ===== -->
  <section class="bg-obc-tan py-16 px-6 lg:px-20 flex flex-col items-center gap-10">
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR SERVICES</span>
      <h2 class="font-heading text-obc-dark text-3xl lg:text-4xl">Built for Every Scale of Construction</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 w-full">
      <!-- Card 1: Civil Works -->
      <div class="bg-obc-cream p-7 flex flex-col gap-4">
        <HardHat class="text-obc-orange" size={28} />
        <h3 class="font-heading text-obc-dark text-xl">Civil Works</h3>
        <p class="text-obc-body text-sm leading-relaxed flex-1">
          Roads, stormwater, earthworks, and bulk infrastructure — engineered for durability and built to last.
        </p>
        <a href="/services" class="text-obc-orange text-xs font-bold tracking-wider uppercase hover:underline">LEARN MORE →</a>
      </div>

      <!-- Card 2: Building Construction -->
      <div class="bg-obc-cream p-7 flex flex-col gap-4">
        <Building2 class="text-obc-orange" size={28} />
        <h3 class="font-heading text-obc-dark text-xl">Building Construction</h3>
        <p class="text-obc-body text-sm leading-relaxed flex-1">
          Residential, commercial, and government facilities constructed with precision and full regulatory compliance.
        </p>
        <a href="/services" class="text-obc-orange text-xs font-bold tracking-wider uppercase hover:underline">LEARN MORE →</a>
      </div>

      <!-- Card 3: Infrastructure -->
      <div class="bg-obc-cream p-7 flex flex-col gap-4">
        <Landmark class="text-obc-orange" size={28} />
        <h3 class="font-heading text-obc-dark text-xl">Infrastructure</h3>
        <p class="text-obc-body text-sm leading-relaxed flex-1">
          Water, sanitation, and public infrastructure projects that serve and uplift communities across South Africa.
        </p>
        <a href="/services" class="text-obc-orange text-xs font-bold tracking-wider uppercase hover:underline">LEARN MORE →</a>
      </div>

      <!-- Card 4: Renovations & Maintenance -->
      <div class="bg-obc-cream p-7 flex flex-col gap-4">
        <Wrench class="text-obc-orange" size={28} />
        <h3 class="font-heading text-obc-dark text-xl">Renovations & Maintenance</h3>
        <p class="text-obc-body text-sm leading-relaxed flex-1">
          Upgrading and maintaining existing structures to meet modern standards, safely and efficiently.
        </p>
        <a href="/services" class="text-obc-orange text-xs font-bold tracking-wider uppercase hover:underline">LEARN MORE →</a>
      </div>
    </div>
  </section>

  <!-- ===== HOW WE WORK ===== -->
  <section class="bg-obc-dark py-20 px-6 lg:px-24 flex flex-col items-center gap-16">
    <div class="flex flex-col items-center gap-4 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR PROCESS</span>
      <h2 class="font-heading text-obc-cream text-4xl lg:text-5xl">From Brief to Handover</h2>
      <p class="text-obc-muted max-w-xl text-center leading-relaxed">
        We manage every phase of your project with transparency, expertise, and accountability — so you can focus on what matters most.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 w-full">
      <!-- Step 01 -->
      <div class="flex flex-col items-center gap-4">
        <div class="w-[52px] h-[52px] rounded-full bg-obc-orange flex items-center justify-center flex-shrink-0">
          <span class="font-heading text-white text-lg leading-none">01</span>
        </div>
        <h4 class="text-obc-cream text-sm font-bold text-center uppercase tracking-wide">Project Brief & Assessment</h4>
        <p class="text-obc-muted text-[13px] text-center leading-relaxed">
          We engage with you to fully understand your requirements, site conditions, and project objectives.
        </p>
      </div>

      <!-- Step 02 -->
      <div class="flex flex-col items-center gap-4">
        <div class="w-[52px] h-[52px] rounded-full bg-obc-orange flex items-center justify-center flex-shrink-0">
          <span class="font-heading text-white text-lg leading-none">02</span>
        </div>
        <h4 class="text-obc-cream text-sm font-bold text-center uppercase tracking-wide">Planning & Compliance</h4>
        <p class="text-obc-muted text-[13px] text-center leading-relaxed">
          Detailed project planning, scheduling, and ensuring all regulatory and compliance requirements are met upfront.
        </p>
      </div>

      <!-- Step 03 -->
      <div class="flex flex-col items-center gap-4">
        <div class="w-[52px] h-[52px] rounded-full bg-obc-orange flex items-center justify-center flex-shrink-0">
          <span class="font-heading text-white text-lg leading-none">03</span>
        </div>
        <h4 class="text-obc-cream text-sm font-bold text-center uppercase tracking-wide">Procurement & Mobilisation</h4>
        <p class="text-obc-muted text-[13px] text-center leading-relaxed">
          Sourcing quality materials and mobilising our skilled team and resources for efficient site deployment.
        </p>
      </div>

      <!-- Step 04 -->
      <div class="flex flex-col items-center gap-4">
        <div class="w-[52px] h-[52px] rounded-full bg-obc-orange flex items-center justify-center flex-shrink-0">
          <span class="font-heading text-white text-lg leading-none">04</span>
        </div>
        <h4 class="text-obc-cream text-sm font-bold text-center uppercase tracking-wide">Construction & Oversight</h4>
        <p class="text-obc-muted text-[13px] text-center leading-relaxed">
          Rigorous on-site management and quality control throughout the construction phase to ensure excellence.
        </p>
      </div>

      <!-- Step 05 -->
      <div class="flex flex-col items-center gap-4">
        <div class="w-[52px] h-[52px] rounded-full bg-obc-orange flex items-center justify-center flex-shrink-0">
          <span class="font-heading text-white text-lg leading-none">05</span>
        </div>
        <h4 class="text-obc-cream text-sm font-bold text-center uppercase tracking-wide">Handover & Maintenance</h4>
        <p class="text-obc-muted text-[13px] text-center leading-relaxed">
          Smooth project handover with full documentation, and ongoing maintenance support as required.
        </p>
      </div>
    </div>

    <!-- CTA Row -->
    <div class="flex flex-col sm:flex-row items-center gap-6 mt-4">
      <span class="font-heading text-obc-cream text-xl lg:text-2xl">Ready to start your project?</span>
      <a
        href="/contact"
        class="bg-obc-orange text-obc-cream text-xs font-bold tracking-widest px-8 py-4 uppercase hover:bg-orange-700 transition-colors"
      >
        START YOUR PROJECT
      </a>
    </div>
  </section>

  <!-- ===== FEATURED PROJECTS ===== -->
  <section class="bg-obc-cream py-16 px-6 lg:px-20">
    <div class="flex flex-col gap-8">
      <div class="flex flex-col gap-3">
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">FEATURED PROJECTS</span>
        <h2 class="font-heading text-obc-dark text-3xl lg:text-4xl">Work That Speaks for Itself</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <!-- Project 1 -->
        <div class="bg-obc-warm overflow-hidden">
          <div class="h-[220px] overflow-hidden">
            <img
              src="/images/projects-1.jpg"
              alt="Outfall Sewer Pipeline Repair Works"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 flex flex-col gap-3">
            <span class="inline-block bg-obc-orange text-obc-cream text-[10px] font-bold tracking-widest px-3 py-1 uppercase w-fit">
              CIVIL WORKS
            </span>
            <h3 class="font-heading text-obc-dark text-lg">Outfall Sewer Pipeline Repair Works</h3>
            <p class="text-obc-body text-sm">Mahikeng, North West</p>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="bg-obc-warm overflow-hidden">
          <div class="h-[220px] overflow-hidden">
            <img
              src="/images/projects-2.jpg"
              alt="Mahikeng Veterinary Office Renovations"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 flex flex-col gap-3">
            <span class="inline-block bg-obc-dark text-obc-cream text-[10px] font-bold tracking-widest px-3 py-1 uppercase w-fit">
              GOVERNMENT
            </span>
            <h3 class="font-heading text-obc-dark text-lg">Mahikeng Veterinary Office Renovations</h3>
            <p class="text-obc-body text-sm">Mahikeng, North West</p>
          </div>
        </div>

        <!-- Project 3 -->
        <div class="bg-obc-warm overflow-hidden">
          <div class="h-[220px] overflow-hidden">
            <img
              src="/images/projects-3.jpg"
              alt="Ikageng Secondary School Renovation"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5 flex flex-col gap-3">
            <span class="inline-block bg-obc-orange text-obc-cream text-[10px] font-bold tracking-widest px-3 py-1 uppercase w-fit">
              GOVERNMENT
            </span>
            <h3 class="font-heading text-obc-dark text-lg">Ikageng Secondary School Renovation</h3>
            <p class="text-obc-body text-sm">Ikageng, North West</p>
          </div>
        </div>
      </div>

      <div class="flex justify-center mt-2">
        <a
          href="/projects"
          class="border-2 border-obc-dark text-obc-dark text-xs font-bold tracking-widest px-8 py-4 uppercase hover:bg-obc-dark hover:text-obc-cream transition-colors"
        >
          VIEW ALL PROJECTS
        </a>
      </div>
    </div>
  </section>

  <!-- ===== COMPLIANCE HIGHLIGHTS ===== -->
  <section class="bg-obc-tan py-16 lg:py-[72px] px-6 lg:px-20">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-16 items-start">
      <!-- Left Column -->
      <div class="max-w-md flex flex-col gap-7">
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">TENDER-READY</span>
        <h2 class="font-heading text-obc-dark text-3xl lg:text-4xl leading-tight">Every Document. Always Current.</h2>
        <p class="text-obc-body text-[15px] leading-relaxed">
          Procurement officers and tender evaluators can rely on Omphile Botshelo Construction for a complete and current compliance profile. We maintain all required certifications, registrations, and accreditations — so your evaluation process is seamless.
        </p>
        <div>
          <a
            href="/compliance"
            class="inline-block bg-obc-orange text-obc-cream text-xs font-bold tracking-widest px-7 py-4 uppercase hover:bg-orange-700 transition-colors"
          >
            View Full Compliance Page
          </a>
        </div>
      </div>

      <!-- Right Column: Compliance Cards -->
      <div class="flex-1 grid grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Card 1 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <BadgeCheck class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">CIDB Grading Certificate</span>
        </div>

        <!-- Card 2 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <Users class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">B-BBEE Certificate</span>
        </div>

        <!-- Card 3 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <FileCheck class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">Tax Clearance</span>
        </div>

        <!-- Card 4 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <Database class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">CSD Registration</span>
        </div>

        <!-- Card 5 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <Shield class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">COIDA Letter</span>
        </div>

        <!-- Card 6 -->
        <div class="bg-white p-5 flex flex-col gap-3">
          <Building2 class="text-obc-orange" size={22} />
          <span class="text-obc-dark text-[13px] font-semibold">CIPC Registration</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY OBC ===== -->
  <section class="bg-obc-dark py-16 px-6 lg:px-20 flex flex-col items-center gap-12">
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">WHY OMPHILE BOTSHELO</span>
      <h2 class="font-heading text-obc-cream text-3xl lg:text-4xl">The Advantage You Need</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 w-full max-w-5xl">
      <!-- Item 1 -->
      <div class="flex flex-col gap-4">
        <Award class="text-obc-orange" size={32} />
        <h3 class="font-heading text-obc-cream text-xl">Established Track Record</h3>
        <p class="text-obc-muted text-[15px] leading-relaxed">
          A proven track record of successful project delivery across civil works, building construction, and infrastructure across North West province and beyond.
        </p>
      </div>

      <!-- Item 2 -->
      <div class="flex flex-col gap-4">
        <ShieldCheck class="text-obc-orange" size={32} />
        <h3 class="font-heading text-obc-cream text-xl">Compliance-Ready</h3>
        <p class="text-obc-muted text-[15px] leading-relaxed">
          Our full suite of up-to-date compliance documentation — CIDB, B-BBEE, CSD, COIDA, and more — means zero delays in the tender and procurement process.
        </p>
      </div>

      <!-- Item 3 -->
      <div class="flex flex-col gap-4">
        <Layers class="text-obc-orange" size={32} />
        <h3 class="font-heading text-obc-cream text-xl">Scalable Delivery</h3>
        <p class="text-obc-muted text-[15px] leading-relaxed">
          From small community upgrades to multi-million rand government contracts, our experienced team and proven processes scale to meet any project demand.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="bg-obc-cream">
    <!-- Top: Cards -->
    <div class="py-20 px-6 lg:px-[120px] flex flex-col items-center gap-14">
      <div class="flex flex-col items-center gap-3 text-center">
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">WHAT OUR CLIENTS SAY</span>
        <h2 class="font-heading text-obc-dark text-3xl lg:text-4xl max-w-2xl text-center leading-tight">
          Trusted by Government & Private Sector Alike
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 w-full">
        <!-- Testimonial 1 -->
        <div class="bg-obc-tan p-8 flex flex-col gap-5">
          <span class="font-heading text-obc-orange text-7xl leading-none">"</span>
          <p class="text-obc-dark text-sm leading-relaxed italic">
            Omphile Botshelo Construction delivered our municipal infrastructure project on time and within budget. Their team maintained full compliance throughout, and communication was excellent from start to finish. We will not hesitate to work with them again.
          </p>
          <div class="flex flex-col gap-1 mt-auto">
            <span class="text-obc-dark font-semibold text-sm">Thabo Molefe</span>
            <span class="text-obc-body text-xs">Director of Infrastructure, Tshwane Municipality</span>
            <span class="inline-block bg-obc-orange text-obc-cream text-[10px] font-bold tracking-widest px-3 py-1 uppercase w-fit mt-2">
              GOVERNMENT
            </span>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-obc-tan p-8 flex flex-col gap-5">
          <span class="font-heading text-obc-orange text-7xl leading-none">"</span>
          <p class="text-obc-dark text-sm leading-relaxed italic">
            We engaged OBC for our commercial mixed-use development and were thoroughly impressed by their professionalism, attention to detail, and commitment to quality. The project was delivered to a high standard and we have since recommended them to several of our partners.
