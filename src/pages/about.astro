---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import { ShieldCheck, Award, Users } from 'lucide-astro';
---

<Layout title="About Us" description="Learn about Omphile Botshelo Construction — a proudly South African construction company established in 2008, committed to quality, community, and transformation.">

  <!-- Navbar -->
  <Navbar active="About" />

  <!-- Hero -->
  <section class="bg-obc-dark h-[300px] lg:h-[520px] flex flex-col items-center justify-center gap-5 px-6 lg:px-[120px] text-center">
    <span class="bg-obc-orange px-4 py-1.5 text-obc-tan text-xs font-semibold tracking-[2px] uppercase">
      100% B-BBEE COMPANY
    </span>
    <h1 class="font-heading text-obc-cream text-5xl lg:text-[80px] leading-tight">
      Who We Are
    </h1>
    <div class="w-[60px] h-[3px] bg-obc-orange"></div>
    <p class="text-obc-muted text-lg text-center max-w-[680px] leading-relaxed">
      A 100% B-BBEE company with four distinctive disciplines — Construction, Supply and Training — committed to becoming South Africa's first preferred leading developmental practice.
    </p>
  </section>

  <!-- Company Story -->
  <section class="flex flex-col lg:flex-row">
    <!-- Image -->
    <div class="w-full lg:w-[620px] h-[400px] lg:h-auto overflow-hidden flex-shrink-0">
      <img
        src="/images/about.jpg"
        alt="Construction site — Omphile Botshelo Construction"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <!-- Content -->
    <div class="bg-obc-cream p-10 lg:p-16 flex flex-col gap-5 justify-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR STORY</span>
      <h2 class="font-heading text-obc-dark text-3xl lg:text-[40px] leading-tight">
        Built on Trust, Grown Through Service
      </h2>
      <div class="w-[48px] h-[3px] bg-obc-orange"></div>
      <p class="text-obc-body text-[15px] leading-[1.8]">
        OMPHILE BOTSHELO (Pty) Ltd is a 100% Broad Based Black Economic Empowerment Company that has four distinctive disciplines focused on special areas involving different areas of Construction, Supply and Training.
      </p>
      <p class="text-obc-body text-[15px] leading-[1.8]">
        The team has extensive experience of providing professional services where needed and work as a collective to accomplish our goals. Our company has an experienced team of Management Personnel who are responsible for making strategic decisions, management who work closely with workers and the staff that is skilled in their respective fields.
      </p>
      <p class="text-obc-body text-[15px] leading-[1.8]">
        Our objective is to provide our clients with sound engineering and value for money solutions that meet their needs and expectations. We are committed to becoming the first preferred leading service provider of choice to accommodate black economic growth in South Africa.
      </p>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="bg-obc-tan py-20 px-6 lg:px-[120px] flex flex-col items-center gap-14">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR VALUES</span>
      <h2 class="font-heading text-obc-dark text-4xl">What We Stand For</h2>
      <p class="text-obc-body text-base max-w-[520px]">
        Our work is guided by principles that have shaped who we are and how we deliver.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid lg:grid-cols-3 gap-6 w-full">
      <!-- Integrity & Trust -->
      <div class="bg-obc-cream p-10 flex flex-col gap-5">
        <ShieldCheck class="text-obc-orange w-9 h-9" />
        <h3 class="font-heading text-obc-dark text-2xl">Integrity &amp; Trust</h3>
        <div class="w-[36px] h-[2px] bg-obc-orange"></div>
        <p class="text-obc-body text-[15px] leading-relaxed">
          We act with integrity and are trusted by all those who deal with us. Our clients, partners, and communities rely on us because we do what we say — without exception.
        </p>
      </div>

      <!-- Quality & Continuous Improvement -->
      <div class="bg-obc-dark p-10 flex flex-col gap-5">
        <Award class="text-obc-orange w-9 h-9" />
        <h3 class="font-heading text-obc-cream text-2xl">Quality &amp; Improvement</h3>
        <div class="w-[36px] h-[2px] bg-obc-orange"></div>
        <p class="text-obc-muted text-[15px] leading-relaxed">
          We consistently deliver a quality service to our clients and seek to continually improve in everything we do. Excellence is not a goal — it is our baseline on every project.
        </p>
      </div>

      <!-- Responsiveness -->
      <div class="bg-obc-cream p-10 flex flex-col gap-5">
        <Users class="text-obc-orange w-9 h-9" />
        <h3 class="font-heading text-obc-dark text-2xl">Responsiveness</h3>
        <div class="w-[36px] h-[2px] bg-obc-orange"></div>
        <p class="text-obc-body text-[15px] leading-relaxed">
          We continually and reliably respond when requested by our clients, and communicate excellently with all stakeholders and client representatives throughout every project.
        </p>
      </div>
    </div>
  </section>

  <!-- CIDB Credentials -->
  <section class="bg-obc-dark py-20 px-6 lg:px-[120px] flex flex-col items-center gap-16">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">CREDENTIALS &amp; COMPLIANCE</span>
      <h2 class="font-heading text-obc-cream text-4xl">Certified. Graded. Trusted.</h2>
      <p class="text-obc-muted text-base max-w-[560px]">
        Our credentials reflect our commitment to industry standards, transformation, and professional excellence.
      </p>
    </div>

    <!-- Stats -->
    <div class="flex flex-col lg:flex-row w-full divide-y lg:divide-y-0 lg:divide-x divide-obc-divider">
      <!-- CIDB -->
      <div class="flex flex-col items-center gap-3 text-center flex-1 py-6 lg:py-0">
        <span class="font-heading text-obc-orange text-6xl">CIDB</span>
        <span class="text-obc-muted text-xs tracking-[2px] font-semibold uppercase">REGISTRATION NO.</span>
        <p class="text-obc-body text-sm max-w-[220px]">Construction Industry Development Board — Reg. 10032299</p>
      </div>

      <!-- B-BBEE -->
      <div class="flex flex-col items-center gap-3 text-center flex-1 py-6 lg:py-0">
        <span class="font-heading text-obc-orange text-6xl">100%</span>
        <span class="text-obc-muted text-xs tracking-[2px] font-semibold uppercase">B-BBEE OWNED</span>
        <p class="text-obc-body text-sm max-w-[220px]">100% Broad Based Black Economic Empowerment company</p>
      </div>

      <!-- NHBRC -->
      <div class="flex flex-col items-center gap-3 text-center flex-1 py-6 lg:py-0">
        <span class="font-heading text-obc-orange text-6xl">NHBRC</span>
        <span class="text-obc-muted text-xs tracking-[2px] font-semibold uppercase">REGISTRATION NO.</span>
        <p class="text-obc-body text-sm max-w-[220px]">National Home Builders Registration Council — Reg. 1-175685280</p>
      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="bg-obc-cream py-20 px-6 lg:px-[120px] flex flex-col items-center gap-14">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OUR LEADERSHIP</span>
      <h2 class="font-heading text-obc-dark text-4xl">The People Behind the Work</h2>
      <p class="text-obc-body text-base max-w-[500px]">
        A dedicated team of construction professionals committed to excellence on every project.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid lg:grid-cols-3 gap-6 w-full">
      <!-- Strategic Management -->
      <div class="bg-obc-cream p-10 flex flex-col items-center gap-4 text-center">
        <div class="w-[100px] h-[100px] rounded-full bg-obc-tan"></div>
        <h3 class="font-heading text-obc-dark text-xl">Strategic Management</h3>
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">LEADERSHIP</span>
        <div class="w-[32px] h-[2px] bg-obc-tan"></div>
        <p class="text-obc-body text-sm leading-relaxed">
          Our experienced management personnel are responsible for making strategic decisions and ensuring the company remains aligned with its vision of becoming South Africa's first preferred leading developmental practice.
        </p>
      </div>

      <!-- Site Operations -->
      <div class="bg-obc-dark p-10 flex flex-col items-center gap-4 text-center">
        <div class="w-[100px] h-[100px] rounded-full bg-obc-body"></div>
        <h3 class="font-heading text-obc-cream text-xl">Site Management</h3>
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">OPERATIONS</span>
        <div class="w-[32px] h-[2px] bg-obc-orange"></div>
        <p class="text-obc-muted text-sm leading-relaxed">
          Our management team works closely with workers on the ground, ensuring that every project is executed with precision, safety, and adherence to the highest quality standards across all disciplines.
        </p>
      </div>

      <!-- Skilled Staff -->
      <div class="bg-obc-cream p-10 flex flex-col items-center gap-4 text-center">
        <div class="w-[100px] h-[100px] rounded-full bg-obc-tan"></div>
        <h3 class="font-heading text-obc-dark text-xl">Skilled Specialists</h3>
        <span class="text-obc-orange text-xs font-semibold tracking-[2px] uppercase">TECHNICAL STAFF</span>
        <div class="w-[32px] h-[2px] bg-obc-tan"></div>
        <p class="text-obc-body text-sm leading-relaxed">
          Our staff are skilled in their respective fields across Construction, Supply and Training — bringing deep expertise to every project and providing a platform for career development within the company.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    heading="Ready to Work With Us?"
    subtext="Let's build together. From government contracts to private developments — we deliver with pride."
    primaryLabel="Contact Us Today"
    primaryHref="/contact"
    secondaryLabel="View Our Projects"
    secondaryHref="/projects"
  />

  <!-- Footer -->
  <Footer active="About Us" />

</Layout>
