---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

const projects = [
  {
    img: '/images/projects-1.jpg',
    location: 'MAHIKENG',
    category: 'CIVIL WORKS',
    title: 'Outfall Sewer Pipeline Repair Works',
    description: 'Sub construction of outfall sewer pipeline repair works.',
    year: '2025–2026',
    value: 'R1,532,229.98',
  },
  {
    img: '/images/projects-2.jpg',
    location: 'MAHIKENG',
    category: 'GOVERNMENT',
    title: 'Mahikeng Veterinary Office Renovations',
    description: 'Renovations and repairs at Mahikeng Veterinary Office.',
    year: 'COMPLETED 2022',
    value: 'R999,000.00',
  },
  {
    img: '/images/projects-3.jpg',
    location: 'IKAGENG',
    category: 'GOVERNMENT',
    title: 'Ikageng Secondary School Renovation',
    description: 'Sub construction renovation of Ikageng Secondary School (via OPT Lerato Trading).',
    year: 'NORTH WEST',
    value: 'R767,000.00',
  },
  {
    img: '/images/projects-4.jpg',
    location: 'MAHIKENG',
    category: 'BUILDING',
    title: 'Tuck Shop Renovation at Old BPG',
    description: 'Renovation of tuck shop at Old BPG.',
    year: 'NORTH WEST',
    value: 'R93,322.00',
  },
  {
    img: '/images/projects-5.jpg',
    location: 'NORTH WEST',
    category: 'CIVIL WORKS',
    title: 'Concrete Kerbs & Drains R49 and D512',
    description: 'Sub contractor — concrete kerbs, channelling and drains on R49 and D512 (via Phezulu Plant).',
    year: 'NORTH WEST',
    value: 'R448,020.70',
  },
  {
    img: '/images/projects-6.jpg',
    location: 'BOPHELONG',
    category: 'BUILDING',
    title: 'Bophelong Tiling & Painting',
    description: 'Construction in Bophelong — tiling and painting works.',
    year: 'COMPLETED 2019',
    value: 'R154,316.10',
  },
];

function getCategoryBg(category: string): string {
  if (category === 'GOVERNMENT' || category === 'CIVIL WORKS') return 'bg-obc-orange';
  if (category === 'BUILDING') return 'bg-obc-orange';
  return 'bg-obc-body';
}
---

<Layout title="Our Projects" description="Explore Omphile Botshelo Construction's track record of delivery across South Africa — government, private and civil works projects.">

  <!-- Navbar -->
  <Navbar active="Projects" />

  <!-- Hero -->
  <section class="relative bg-obc-dark h-[250px] lg:h-[340px] flex flex-col justify-center gap-4 px-6 lg:px-14 overflow-hidden">
    <h1 class="font-heading text-obc-cream text-4xl lg:text-6xl font-bold">Our Projects</h1>
    <p class="text-obc-tan text-lg">A track record of delivery across South Africa</p>
    <!-- Accent bar -->
    <div class="w-[60px] h-[4px] bg-obc-orange lg:absolute lg:bottom-0 lg:left-14"></div>
  </section>

  <!-- Projects Grid -->
  <section class="bg-obc-cream px-6 lg:px-14 py-12 flex flex-col gap-5">
    <!-- Header row -->
    <div class="flex justify-between items-center">
      <h2 class="font-heading text-obc-dark text-2xl font-bold">Selected Projects</h2>
      <span class="text-obc-muted text-sm">6 projects</span>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project) => (
        <div class="bg-obc-tan overflow-hidden">
          <img
            src={project.img}
            alt={project.title}
            class="h-[200px] w-full object-cover"
            loading="lazy"
          />
          <div class="p-5 flex flex-col gap-3">
            <!-- Tags -->
            <div class="flex gap-2">
              <span class="bg-obc-dark text-obc-cream text-[9px] font-semibold tracking-wider px-2.5 py-1">
                {project.location}
              </span>
              <span class={`${getCategoryBg(project.category)} text-obc-cream text-[9px] font-semibold tracking-wider px-2.5 py-1`}>
                {project.category}
              </span>
            </div>
            <!-- Title -->
            <h3 class="font-heading text-obc-dark text-lg font-bold">{project.title}</h3>
            <!-- Description -->
            <p class="text-obc-body text-[13px] leading-relaxed">{project.description}</p>
            <!-- Year -->
            <span class="text-obc-muted text-xs font-semibold tracking-wider">{project.year}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Project -->
  <section class="bg-obc-dark px-6 lg:px-14 py-12 flex flex-col gap-6">
    <span class="text-obc-muted text-xs font-semibold tracking-[2px]">FEATURED PROJECT</span>

    <div class="bg-[#1a1a1a] flex flex-col lg:flex-row overflow-hidden h-auto lg:h-[420px]">
      <!-- Image -->
      <img
        src="/images/projects-hero.jpg"
        alt="Outfall Sewer Pipeline Repair Works — Mahikeng"
        class="w-full lg:w-[560px] h-[250px] lg:h-full object-cover flex-shrink-0"
        loading="lazy"
      />

      <!-- Details -->
      <div class="flex-1 p-8 lg:p-10 flex flex-col gap-5">
        <!-- Tags -->
        <div class="flex gap-2 flex-wrap">
          <span class="bg-obc-orange text-obc-cream text-[9px] font-semibold tracking-wider px-2.5 py-1">CIVIL WORKS</span>
          <span class="bg-obc-dark border border-obc-body text-obc-cream text-[9px] font-semibold tracking-wider px-2.5 py-1">2025–2026</span>
          <span class="bg-obc-dark border border-obc-body text-obc-cream text-[9px] font-semibold tracking-wider px-2.5 py-1">MAHIKENG</span>
        </div>

        <!-- Title -->
        <h2 class="font-heading text-obc-cream text-2xl lg:text-3xl font-bold">Outfall Sewer Pipeline Repair Works</h2>

        <!-- Stats row -->
        <div class="flex gap-10 flex-wrap">
          <div class="flex flex-col gap-1">
            <span class="text-obc-muted text-[10px] tracking-wider font-semibold uppercase">DURATION</span>
            <span class="font-heading text-obc-tan text-xl">2025–2026</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-obc-muted text-[10px] tracking-wider font-semibold uppercase">SECTOR</span>
            <span class="font-heading text-obc-tan text-xl">Municipal Civil</span>
          </div>
        </div>

        <!-- Scope -->
        <span class="text-obc-muted text-[10px] tracking-wider font-semibold uppercase">PROJECT SCOPE</span>
        <p class="text-obc-tan text-sm leading-relaxed">
          Sub construction of outfall sewer pipeline repair works in Mahikeng, North West province. Project contact: Mr Motati (018 381 1071). Works involve pipeline rehabilitation and repair to municipal sewer infrastructure.
        </p>

      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-obc-orange h-auto lg:h-[180px] px-6 lg:px-14 py-10 lg:py-0 flex flex-col lg:flex-row justify-between items-center gap-6">
    <!-- Left -->
    <div class="flex flex-col gap-2 text-center lg:text-left">
      <h2 class="font-heading text-obc-cream text-xl lg:text-[28px]">Interested in our capabilities?</h2>
      <p class="text-obc-tan text-[15px]">Request our company profile or speak with our project team.</p>
    </div>
    <!-- Right -->
    <div class="flex gap-4 flex-wrap justify-center">
      <a href="#" class="bg-obc-cream text-obc-orange text-xs font-semibold tracking-wider px-6 py-3">
        REQUEST PROFILE
      </a>
      <a href="/contact" class="border border-obc-cream text-obc-cream text-xs font-semibold tracking-wider px-6 py-3">
        CONTACT US
      </a>
    </div>
  </section>

  <!-- Footer -->
  <Footer active="Projects" />

</Layout>
